## Kali Base
kali-base (){
    sudo podman run \
    -it \
    --rm \
    --security-opt label=disable \
    --network host \
    --privileged \
    -v $HOME:$HOME \
    ghcr.io/sir-mudkip/kali-base:latest
}

## Kali-VM
kali-vm (){
    sudo podman run \
    -d \
    --name kali \
    --security-opt label=disable \
    --network host \
    --privileged \
    -v $HOME:$HOME \
    ghcr.io/sir-mudkip/kali-cloud:latest \
    /sbin/init
}
